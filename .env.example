# ---- Telegram MTProto (from https://my.telegram.org -> API development tools) ----
# One API ID/Hash can be reused across all accounts you control.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ---- OpenAI ----
OPENAI_API_KEY=
# Model used to generate keyboard-warrior replies
OPENAI_MODEL=gpt-4o-mini

# ---- Supabase (new project: telegram-keyboardwarrior) ----
# Public values (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server/worker only - never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Session encryption ----
# 32-byte key, hex-encoded (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=

# ---- Worker control API ----
# The long-running Node worker that holds Telegram connections.
WORKER_PORT=8787
# Use 127.0.0.1 locally; set 0.0.0.0 when deploying the worker (Docker/Railway/Render).
WORKER_HOST=127.0.0.1
WORKER_URL=http://127.0.0.1:8787
# Shared secret between dashboard and worker control API.
WORKER_SECRET=change-me
